# SAMARTH API Environment Variables Configuration

# 1. API Keys (Mandatory)
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# 2. Security (Optional)
SECRET_KEY=samarth_secret_key_2026

# 3. Database URL (Optional)
DATABASE_URL=sqlite:///./samarth.db

# 4. Tesseract OCR Path (Mandatory for scanned document ingestion on Windows)
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
